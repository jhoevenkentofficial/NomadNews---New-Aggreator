<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /api/php/

    # Handle /latest
    RewriteRule ^latest$ api.php?route=latest [QSA,L]
    
    # Handle /category/:name
    RewriteRule ^category/(.*)$ api.php?route=category&category=$1 [QSA,L,B]
    
    # Handle /region/:name
    RewriteRule ^region/(.*)$ api.php?route=region&region=$1 [QSA,L,B]
    
    # Handle /source/:name
    RewriteRule ^source/(.*)$ api.php?route=source&source=$1 [QSA,L,B]
    
    # Handle /search
    RewriteRule ^search$ api.php?route=search [QSA,L]
    
    # Handle /trending
    RewriteRule ^trending$ api.php?route=trending [QSA,L]
    
    # Handle /sources
    RewriteRule ^sources$ api.php?route=sources [QSA,L]
    
    # Handle /health
    RewriteRule ^health$ api.php?route=health [QSA,L]
    
    # Handle /manual (Admin article submit)
    RewriteRule ^manual$ api.php?route=manual [QSA,L]

    # Handle /fetch (Manual trigger)
    RewriteRule ^fetch$ fetch.php?run=1 [QSA,L]
</IfModule>
