{
  "version": 2,
  "functions": {
    "api/backend/server.js": {
      "runtime": "vercel-node@latest"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/news/fetch",
      "schedule": "0 0 * * *"
    }
  ]
}
