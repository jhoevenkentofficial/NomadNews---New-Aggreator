{
  "buildCommand": "npm install && cd frontend && npm install && npm run build",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/assets/(.*)", "destination": "/frontend/dist/assets/$1" },
    { "source": "/(.*)", "destination": "/frontend/dist/index.html" }
  ],
  "crons": [
    {
      "path": "/api/news/fetch",
      "schedule": "0 * * * *"
    }
  ]
}
